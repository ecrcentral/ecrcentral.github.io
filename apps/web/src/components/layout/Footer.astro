---
const currentYear = new Date().getFullYear()
const githubRepo = 'https://github.com/ecrcentral/ecrcentral.github.io'
---

<footer class="footer" aria-label="Site footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div>
        <div class="footer-brand" style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
          <a href="https://elifesciences.org/">
            <img src="/images/powered-by-eLife.svg" alt="Powered by eLife" height="50" />
          </a>
          <a href="https://elifesciences.org/community/ambassadors" target="_blank" rel="noopener noreferrer">
            <img src="/images/elife-ambassadors.png" alt="eLife Ambassadors" height="50" />
          </a>
        </div>
        <p class="footer-tagline">
          ECRcentral is a community-maintained directory of funding opportunities, travel grants,
          and resources for ECRs worldwide.
        </p>
        <div style="display:flex;gap:12px;align-items:center;">
          <a
            href={githubRepo}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="ECRcentral on GitHub"
            style="display:flex;align-items:center;gap:6px;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Opportunities column -->
      <div>
        <p class="footer-col-title">Opportunities</p>
        <nav class="footer-links" aria-label="Opportunities">
          <a href="/fundings/" class="footer-link">Funding Opportunities</a>
          <a href="/travel-grants/" class="footer-link">Travel Grants</a>
          <a href="/resources/" class="footer-link">Resources</a>
          <a href="/funders/" class="footer-link">Funders</a>
        </nav>
      </div>

      <!-- Contributing column -->
      <div>
        <p class="footer-col-title">Contributing</p>
        <nav class="footer-links" aria-label="Contributing">
          <a href="/contribute/" class="footer-link">How to Contribute</a>
          <a
            href={`${githubRepo}/issues/new?template=funding.yml`}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >Add Funding</a>
          <a
            href={`${githubRepo}/issues/new?template=travel-grant.yml`}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >Add Travel Grant</a>
          <a
            href={`${githubRepo}/issues/new?template=resource.yml`}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >Add Resource</a>
        </nav>
      </div>

      <!-- About column -->
      <div>
        <p class="footer-col-title">About</p>
        <nav class="footer-links" aria-label="About">
          <a href="/about/" class="footer-link">About ECRcentral</a>
          <a href="/about/#editorial-policy" class="footer-link">Editorial Policy</a>
          <a
            href={githubRepo}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >Source Code</a>
          <a
            href={`${githubRepo}/issues/new?template=report_issue.yml`}
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer"
          >Report an Issue</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p>
        &copy; {currentYear} ECRcentral &mdash;
        Developed by eLife Ambassadors and licensed under Creative Commons BY 4.0.
      </p>
      <p>
        Built with
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        &bull; Hosted on
        <a href="https://pages.github.com" target="_blank" rel="noopener noreferrer">GitHub Pages</a>
      </p>
    </div>
  </div>
</footer>
