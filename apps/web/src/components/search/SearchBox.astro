---
interface Props {
  placeholder?: string
  value?: string
  id?: string
  name?: string
  ariaLabel?: string
}

const {
  placeholder = 'Search...',
  value = '',
  id = 'search-input',
  name = 'q',
  ariaLabel = 'Search',
} = Astro.props
---

<div class="search-wrapper" style="width:100%;">
  <svg
    class="search-icon"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <input
    type="search"
    id={id}
    name={name}
    class="search-input"
    placeholder={placeholder}
    value={value}
    aria-label={ariaLabel}
    autocomplete="off"
    spellcheck="false"
  />
  {value && (
    <button
      type="button"
      id={`${id}-clear`}
      aria-label="Clear search"
      style="position:absolute;right:12px;background:none;border:none;cursor:pointer;color:var(--color-muted);display:flex;align-items:center;"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  )}
</div>

<script>
  // Show/hide clear button dynamically
  document.querySelectorAll('.search-wrapper').forEach(wrapper => {
    const input = wrapper.querySelector('input[type="search"]') as HTMLInputElement | null
    if (!input) return

    // Emit a custom 'search-change' event that listing pages listen to
    let debounceTimer: ReturnType<typeof setTimeout>
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        input.dispatchEvent(new CustomEvent('search-change', {
          bubbles: true,
          detail: { query: input.value.trim() },
        }))
      }, 200)
    })
  })
</script>
