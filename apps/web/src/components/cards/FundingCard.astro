---
import type { Funding } from '../../lib/schema'

interface Props {
  funding: Funding
  compact?: boolean
}

const { funding, compact = false } = Astro.props

const statusClass: Record<string, string> = {
  active: 'badge-active',
  expired: 'badge-expired',
  archived: 'badge-archived',
  draft: 'badge-draft',
}

function formatDeadline(deadline: string | null): string {
  if (!deadline) return ''
  const d = new Date(deadline)
  if (isNaN(d.getTime())) return deadline
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
}

const dataFunders = (funding.funders ?? []).join(',')
const dataCareerLevels = (funding.career_levels ?? []).join(',')
const dataSubjects = (funding.subjects ?? []).join(',')
const dataFundingPurposes = (funding.funding_purposes ?? []).join(',')
---

<article
  class="card"
  data-id={funding.id}
  data-slug={funding.slug}
  data-status={funding.status}
  data-funders={dataFunders}
  data-career-levels={dataCareerLevels}
  data-subjects={dataSubjects}
  data-funding-purposes={dataFundingPurposes}
  data-applicant-country={funding.applicant_country || ''}
  data-host-country={funding.host_country || ''}
  data-deadline-month={funding.deadline_month || ''}
  data-frequency={funding.frequency || ''}
  data-featured={funding.featured ? 'true' : 'false'}
  data-name={funding.name.toLowerCase()}
  data-search-text={(funding.search_text || funding.name + ' ' + (funding.description || '')).toLowerCase()}
>
  <div class="card-body">
    <!-- Header row: title + badges -->
    <div class="card-header">
      <h3 class="card-title">
        <a href={`/fundings/${funding.slug}/`}>{funding.name}</a>
      </h3>
      <div style="display:flex;gap:6px;flex-shrink:0;align-items:center;flex-wrap:wrap;">
        {funding.featured && (
          <span class="badge badge-featured" title="Featured opportunity">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Featured
          </span>
        )}
        <span class={`badge ${statusClass[funding.status] || 'badge-draft'}`}>
          {funding.status}
        </span>
      </div>
    </div>

    <!-- Funder names -->
    {(funding.funder_names?.length || funding.legacy_funder_name) && (
      <p class="card-meta">
        <span class="card-meta-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span>
            {funding.funder_names?.length
              ? funding.funders.map((slug, i) => (
                  <span>
                    {i > 0 && ', '}
                    <a href={`/funders/${slug}/`} class="text-primary" style="font-size:inherit">
                      {funding.funder_names![i] || slug}
                    </a>
                  </span>
                ))
              : funding.legacy_funder_name
            }
          </span>
        </span>
      </p>
    )}

    <!-- Key metadata row -->
    <div class="card-meta">
      {funding.applicant_country && (
        <span class="card-meta-item" title="Eligible applicant nationality">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          <span style="font-weight:500;margin-right:2px;">Applicant:</span>{funding.applicant_country}
        </span>
      )}
      {funding.host_country && (
        <span class="card-meta-item" title="Host country/region">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span style="font-weight:500;margin-right:2px;">Host:</span>{funding.host_country}
        </span>
      )}
      {funding.deadline && (
        <span class="card-meta-item" title="Application deadline">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {formatDeadline(funding.deadline)}
        </span>
      )}
      {funding.award && (
        <span class="card-meta-item" title="Award amount">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
          </svg>
          {funding.award}
        </span>
      )}
    </div>

    <!-- Description -->
    {!compact && funding.description && (
      <p class="card-description">{funding.description}</p>
    )}

    <!-- Tags: career levels + subjects -->
    {((funding.career_level_names?.length ?? 0) > 0 || funding.career_levels.length > 0) && (
      <div class="tags" style="margin-top:8px;">
        {(funding.career_level_names || funding.career_levels).slice(0, 4).map(level => (
          <span class="tag">{level}</span>
        ))}
        {(funding.career_level_names || funding.career_levels).length > 4 && (
          <span class="tag tag-muted">+{(funding.career_level_names || funding.career_levels).length - 4} more</span>
        )}
      </div>
    )}
  </div>
</article>
