---
import type { TravelGrant } from '../../lib/schema'

interface Props {
  grant: TravelGrant
  compact?: boolean
  homepage?: boolean
}

const { grant, compact = false, homepage = false } = Astro.props
const stripHtml = (html: string | null | undefined) => html?.replace(/<[^>]*>/g, '').trim() ?? ''

const firstFunderLogo = grant.funder_logos?.[0] ?? null
const firstFunderName = grant.funder_names?.[0] ?? grant.legacy_funder_name ?? null
const funderInitials = firstFunderName
  ? firstFunderName.split(' ').slice(0, 2).map((w: string) => w[0]).join('').toUpperCase()
  : '?'

const statusClass: Record<string, string> = {
  active: 'badge-active',
  expired: 'badge-expired',
  archived: 'badge-archived',
  draft: 'badge-draft',
}

function formatDeadline(deadline: string | null): string {
  if (!deadline) return ''
  try {
    const d = new Date(deadline)
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })
  } catch {
    return deadline
  }
}

const membershipRequired = grant.membership?.toLowerCase() === 'yes'
---

<article
  class="card"
  data-id={grant.id}
  data-slug={grant.slug}
  data-status={grant.status}
  data-funders={(grant.funders ?? []).join(',')}
  data-career-levels={(grant.career_levels ?? []).join(',')}
  data-subjects={(grant.subjects ?? []).join(',')}
  data-travel-purposes={(grant.travel_purposes ?? []).join(',')}
  data-membership={grant.membership || ''}
  data-applicant-country={grant.applicant_country || ''}
  data-featured={grant.featured ? 'true' : 'false'}
  data-name={grant.name.toLowerCase()}
  data-search-text={(grant.search_text || grant.name + ' ' + (grant.description || '')).toLowerCase()}
>
  <div class="card-body">
    <!-- Header row -->
    <div class="card-header">
      {homepage && firstFunderName && (
        <div class="card-funder-logo" aria-hidden="true">
          {firstFunderLogo
            ? <img src={firstFunderLogo} alt="" loading="lazy" width="32" height="32" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
            : null}
          <div class="card-funder-logo-fallback" style={`display:${firstFunderLogo ? 'none' : 'flex'}`}>{funderInitials}</div>
        </div>
      )}
      <h3 class="card-title">
        <a href={`/travel-grants/${grant.slug}/`}>{grant.name}</a>
      </h3>
      {!homepage && (
        <div style="display:flex;gap:6px;flex-shrink:0;align-items:center;flex-wrap:wrap;">
          {grant.featured && (
            <span class="badge badge-featured" title="Featured">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              Featured
            </span>
          )}
          {membershipRequired && (
            <span class="badge badge-membership" title="Membership required">
              Members only
            </span>
          )}
          <span class={`badge ${statusClass[grant.status] || 'badge-draft'}`}>
            {grant.status}
          </span>
        </div>
      )}
    </div>

    <!-- Funders -->
    {(grant.funder_names?.length || grant.legacy_funder_name) && (
      <p class="card-meta">
        <span class="card-meta-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span>
            {grant.funder_names?.length
              ? grant.funders.map((slug, i) => (
                  <span>
                    {i > 0 && ', '}
                    <a href={`/funders/${slug}/`} class="text-primary" style="font-size:inherit">
                      {grant.funder_names![i] || slug}
                    </a>
                  </span>
                ))
              : grant.legacy_funder_name
            }
          </span>
        </span>
      </p>
    )}

    <!-- Key metadata -->
    <div class="card-meta">
      {grant.applicant_country && (
        <span class="card-meta-item" title="Eligible applicant country/region">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          {grant.applicant_country}
        </span>
      )}
      {grant.deadline && (
        <span class="card-meta-item" title="Deadline">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {formatDeadline(grant.deadline)}
        </span>
      )}
      {grant.award && (
        <span class="card-meta-item" title="Award amount">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="6" x2="12" y2="18"/>
            <path d="M15 9.5a3 3 0 00-3-2.5h-1a2.5 2.5 0 000 5h2a2.5 2.5 0 010 5h-1a3 3 0 01-3-2.5"/>
          </svg>
          {grant.award}
        </span>
      )}
    </div>

    <!-- Description -->
    {!compact && grant.description && (
      <p class="card-description">{stripHtml(grant.description)}</p>
    )}

    <!-- Career level tags -->
    {((grant.career_level_names?.length ?? 0) > 0 || grant.career_levels.length > 0) && (
      <div class="tags" style="margin-top:8px;">
        {(grant.career_level_names || grant.career_levels).slice(0, 4).map(level => (
          <span class="tag">{level}</span>
        ))}
        {(grant.career_level_names || grant.career_levels).length > 4 && (
          <span class="tag tag-muted">+{(grant.career_level_names || grant.career_levels).length - 4} more</span>
        )}
      </div>
    )}
  </div>
</article>
