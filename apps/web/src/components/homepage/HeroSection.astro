---
interface Props {
  fundingsCount: number
  travelGrantsCount: number
  resourcesCount: number
  fundersCount: number
}

const { fundingsCount, travelGrantsCount, resourcesCount, fundersCount } = Astro.props
---

<section class="hero" aria-labelledby="hero-title">
  <div class="container">
    <div class="hero-inner">
      <h1 class="hero-title" id="hero-title">
        Funding Opportunities for Early Career Researchers
      </h1>
      <p class="hero-subtitle">
        A central platform connecting early career researchers to funding, opportunities, and essential resources.
      </p>

      <!-- Search bar -->
      <form
        id="hero-search-form"
        class="hero-search"
        action="/fundings/"
        method="get"
        role="search"
        aria-label="Search ECRcentral"
      >
        <div class="hero-search-box">
          <svg
            style="position:absolute;left:16px;top:50%;transform:translateY(-50%);color:#6e84a3;pointer-events:none;"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input
            type="search"
            name="q"
            placeholder="Search fundings, grants, resources..."
            class="hero-search-input"
            style="padding-left:48px;"
            aria-label="Search query"
            autocomplete="off"
          />
          <div class="hero-search-divider" aria-hidden="true"></div>
          <select
            id="hero-search-type"
            class="hero-search-select"
            aria-label="Search category"
          >
            <option value="/fundings/">Funding</option>
            <option value="/travel-grants/">Travel Grants</option>
            <option value="/resources/">Resources</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-lg" style="flex-shrink:0;">
          Search
        </button>
      </form>

      <script>
        const form = document.getElementById('hero-search-form') as HTMLFormElement | null
        const select = document.getElementById('hero-search-type') as HTMLSelectElement | null
        if (form && select) {
          form.action = select.value
          select.addEventListener('change', () => { form.action = select.value })
        }
      </script>

      <!-- Quick stats -->
      <div class="hero-stats" role="list" aria-label="Site statistics">
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-number">{fundingsCount.toLocaleString()}</span>
          <span class="hero-stat-label">Funding</span>
        </div>
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-number">{travelGrantsCount.toLocaleString()}</span>
          <span class="hero-stat-label">Travel Grants</span>
        </div>
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-number">{resourcesCount.toLocaleString()}</span>
          <span class="hero-stat-label">Resources</span>
        </div>
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-number">{fundersCount.toLocaleString()}</span>
          <span class="hero-stat-label">Funders</span>
        </div>
      </div>
    </div>
  </div>
</section>
