---
import BaseLayout from '../../components/layout/BaseLayout.astro'
import ResourceCard from '../../components/cards/ResourceCard.astro'
import FacetPanel from '../../components/facets/FacetPanel.astro'
import SearchBox from '../../components/search/SearchBox.astro'
import ViewToggle from '../../components/search/ViewToggle.astro'
import { resources, facets } from '../../lib/data'

const publicResources = resources.filter(r => r.review_status === 'approved' || r.status === 'active')
const url = Astro.url
const initialQuery = url.searchParams.get('q') || ''
const totalCount = publicResources.length
const resourceFacets = facets.resources || {}
---

<BaseLayout
  title="Resources"
  description={`Browse ${totalCount} resources for early career researchers. Filter by category, subject, and more.`}
  canonical="/resources/"
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-header-title">Resources</h1>
      <p class="page-header-subtitle">
        Guides, tools, databases, and services for early career researchers.
      </p>
    </div>
  </div>

  <div class="container" style="padding-top:32px;padding-bottom:64px;">
    <div class="listing-layout">
      <aside aria-label="Filter resources">
        <FacetPanel entityType="resources" facets={resourceFacets} />
      </aside>

      <div>
        <div class="listing-controls" style="margin-bottom:20px;">
          <ViewToggle gridId="resources-grid" />
          <div style="flex:1;">
            <SearchBox
              placeholder="Search resources..."
              value={initialQuery}
              id="resources-search"
              ariaLabel="Search resources"
            />
          </div>
          <p class="listing-count" aria-live="polite">
            Showing <strong id="visible-count">{totalCount}</strong> of {totalCount} resources
          </p>
        </div>

        <div id="no-results" class="no-results" style="display:none;" aria-live="polite">
          <div class="no-results-icon" aria-hidden="true">🔍</div>
          <p class="no-results-title">No resources match your filters</p>
          <p class="text-muted">Try adjusting your search or clearing some filters.</p>
          <button type="button" class="btn btn-outline" style="margin-top:16px;" onclick="window.location.search=''">
            Clear all filters
          </button>
        </div>

        <div class="cards-list" id="resources-grid" aria-label="Resources">
          {publicResources.map(resource => (
            <ResourceCard resource={resource} />
          ))}
        </div>

        <nav id="resources-pagination" class="pagination" aria-label="Pagination"></nav>

        {totalCount === 0 && (
          <div class="no-results">
            <div class="no-results-icon" aria-hidden="true">📭</div>
            <p class="no-results-title">No resources yet</p>
            <p class="text-muted">Be the first to add one!</p>
            <a
              href="https://github.com/ecrcentral/ecrcentral.github.io/issues/new?template=resource.yml"
              class="btn btn-primary"
              style="margin-top:16px;"
              target="_blank"
              rel="noopener noreferrer"
            >
              Add a resource
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const grid = document.getElementById('resources-grid')
  const noResults = document.getElementById('no-results')
  const visibleCountEl = document.getElementById('visible-count')
  const searchInput = document.getElementById('resources-search') as HTMLInputElement | null
  const paginationEl = document.getElementById('resources-pagination')

  const PAGE_SIZE = 20
  let currentPage = 1

  function getFiltersFromURL(): Record<string, string[]> {
    const params = new URLSearchParams(window.location.search)
    const filters: Record<string, string[]> = {}
    for (const [key, val] of params.entries()) {
      if (key === 'q') continue
      if (!filters[key]) filters[key] = []
      filters[key].push(val)
    }
    return filters
  }

  function matchesFilters(card: HTMLElement, filters: Record<string, string[]>, query: string): boolean {
    if (query) {
      const searchText = card.dataset.searchText || card.dataset.name || ''
      if (!searchText.includes(query.toLowerCase())) return false
    }
    if (filters.status?.length && !filters.status.includes(card.dataset.status || '')) return false
    if (filters.category?.length) {
      const cats = (card.dataset.categories || '').split(',').filter(Boolean)
      if (!filters.category.some(c => cats.includes(c))) return false
    }
    if (filters.subject?.length) {
      const subjects = (card.dataset.subjects || '').split(',').filter(Boolean)
      if (!filters.subject.some(s => subjects.includes(s))) return false
    }
    if (filters.featured?.includes('true') && card.dataset.featured !== 'true') return false
    return true
  }

  function getPageNumbers(current: number, total: number): (number | '...')[] {
    if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1)
    const pages: (number | '...')[] = [1]
    if (current > 3) pages.push('...')
    for (let p = Math.max(2, current - 1); p <= Math.min(total - 1, current + 1); p++) pages.push(p)
    if (current < total - 2) pages.push('...')
    pages.push(total)
    return pages
  }

  function renderPagination(total: number) {
    if (!paginationEl) return
    const totalPages = Math.ceil(total / PAGE_SIZE)
    if (totalPages <= 1) { paginationEl.innerHTML = ''; return }
    let html = `<button class="pagination-btn" ${currentPage === 1 ? 'disabled' : ''} data-page="${currentPage - 1}" aria-label="Previous page">&#8249;</button>`
    for (const p of getPageNumbers(currentPage, totalPages)) {
      if (p === '...') html += `<span class="pagination-ellipsis">…</span>`
      else html += `<button class="pagination-btn${p === currentPage ? ' active' : ''}" data-page="${p}" aria-label="Page ${p}"${p === currentPage ? ' aria-current="page"' : ''}>${p}</button>`
    }
    html += `<button class="pagination-btn" ${currentPage === totalPages ? 'disabled' : ''} data-page="${currentPage + 1}" aria-label="Next page">&#8250;</button>`
    paginationEl.innerHTML = html
    paginationEl.querySelectorAll<HTMLButtonElement>('button[data-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        currentPage = parseInt(btn.dataset.page!)
        applyFilters()
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })
    })
  }

  function applyFilters() {
    if (!grid) return
    const filters = getFiltersFromURL()
    const query = searchInput?.value.trim() || new URLSearchParams(window.location.search).get('q') || ''
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('article[data-slug]'))
    const matching = cards.filter(card => matchesFilters(card, filters, query))
    const start = (currentPage - 1) * PAGE_SIZE
    const end = start + PAGE_SIZE
    cards.forEach(card => { card.style.display = 'none' })
    matching.slice(start, end).forEach(card => { card.style.display = '' })
    if (visibleCountEl) visibleCountEl.textContent = String(matching.length)
    if (noResults) noResults.style.display = matching.length === 0 ? '' : 'none'
    if (grid) grid.style.display = matching.length === 0 ? 'none' : ''
    renderPagination(matching.length)
  }

  applyFilters()

  if (searchInput) {
    searchInput.value = new URLSearchParams(window.location.search).get('q') || ''
    searchInput.addEventListener('input', () => { currentPage = 1; applyFilters() })
  }

  window.addEventListener('popstate', () => { currentPage = 1; applyFilters() })
</script>
