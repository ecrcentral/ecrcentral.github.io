{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TravelGrant",
  "type": "object",
  "required": ["id", "slug", "name", "url", "status", "review_status", "source"],
  "properties": {
    "id": {"type": "string"},
    "legacy_id": {"type": ["integer", "null"]},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "name": {"type": "string", "minLength": 1},
    "url": {"type": "string", "minLength": 1},
    "description": {"type": ["string", "null"]},
    "funders": {"type": "array", "items": {"type": "string"}},
    "legacy_funder_name": {"type": ["string", "null"]},
    "applicant_country": {"type": ["string", "null"]},
    "host_country": {"type": ["string", "null"]},
    "award": {"type": ["string", "null"]},
    "deadline": {"type": ["string", "null"]},
    "deadline_raw": {"type": ["string", "null"]},
    "deadline_month": {"type": ["string", "null"]},
    "membership": {"type": ["string", "null"]},
    "membership_time": {"type": ["string", "null"]},
    "purpose_text": {"type": ["string", "null"]},
    "career_levels": {"type": "array", "items": {"type": "string"}},
    "subjects": {"type": "array", "items": {"type": "string"}},
    "travel_purposes": {"type": "array", "items": {"type": "string"}},
    "featured": {"type": "boolean"},
    "review_status": {"type": "string", "enum": ["approved", "pending", "rejected"]},
    "status": {"type": "string", "enum": ["active", "expired", "archived", "draft"]},
    "last_verified": {"type": ["string", "null"]},
    "verified_by": {"type": ["string", "null"]},
    "created_at": {"type": ["string", "null"]},
    "updated_at": {"type": ["string", "null"]},
    "search_text": {"type": ["string", "null"]},
    "source": {"type": "string"}
  },
  "additionalProperties": false
}
